# Copy this file to .env on the host and fill real secrets.
# Never commit .env with Avito or AI provider credentials.

# API_HOST/API_PORT configure the container listener. PORT is also supported
# when a platform injects it. Local Docker Compose keeps HOST_PORT=8000 for the
# browser URL while the container defaults to API_PORT=8000.
API_HOST=0.0.0.0
API_PORT=8000
PORT=

# HOST_PORT is used only by local docker compose port publishing.
HOST_PORT=8000

AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=
AVITO_WEBHOOK_URL=
AVITO_LIVE_SYNC_ENABLED=true

AI_PROVIDER=deepseek

# Optional bot rules overrides.
# AVITO_BOT_RULES_PATH can point to another JSON rules file.
# AVITO_ADMIN_CODE overrides the default admin/debug activation code from bot-rules.json.
AVITO_BOT_RULES_PATH=
AVITO_ADMIN_CODE=

# Storage:
# - set DATABASE_URL to the Bothost PostgreSQL connection string for production;
# - leave it blank to use SQLite.
# If Bothost shared files are enabled, SHARED_DIR is usually provided by the
# platform and SQLite/backups go under $SHARED_DIR/avito-bot/.
DATABASE_URL=
SHARED_DIR=
AVITO_DATABASE_PATH=
AVITO_BACKUP_DIR=
AVITO_BACKUP_INTERVAL_SECONDS=21600
AVITO_BACKUP_RETENTION_COUNT=14

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional fallback when AI_PROVIDER=deepseek.
CODEX_APP_SERVER_BASE_URL=
CODEX_APP_SERVER_API_KEY=
CODEX_APP_SERVER_MODEL=codex

# Optional manager handoff notifications through Telegram.
TELEGRAM_BOT_TOKEN=
MANAGER_TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_TIMEOUT_SECONDS=5

# Runtime diagnostics through the external ai_logger package.
# /api/admin/logs is always kept in memory; set AI_LOGGER_SERVER_URL to forward
# records to the separate ai_logger server or AI_LOGGER_JSONL_PATH for JSONL.
AI_LOGGER_LEVEL=INFO
AI_LOGGER_PROJECT=avito-bot
AI_LOGGER_SERVICE=api
AI_LOGGER_ENVIRONMENT=production
AI_LOGGER_JSONL_PATH=
AI_LOGGER_SERVER_URL=
AI_LOGGER_SERVER_TOKEN=
AI_LOGGER_FALLBACK_JSONL_PATH=.codex-runtime/logs/ai_logger_fallback.jsonl
