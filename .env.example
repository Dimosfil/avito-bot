# Avito API credentials.
# Copy this file to .env locally and fill values there. Never commit .env.

AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

# Fill after the authorized account is known.
AVITO_USER_ID=

# Public HTTPS webhook URL for real Avito Messenger webhooks.
# Local development can use a tunnel later.
AVITO_WEBHOOK_URL=

# Set false when the UI should use stored PostgreSQL/SQLite chats only and not
# poll/send through the live Avito API.
AVITO_LIVE_SYNC_ENABLED=true

# Docker/hosting port settings. The app defaults to port 8000 locally and in
# the Docker image. PORT is still supported when a platform injects it.
API_HOST=0.0.0.0
API_PORT=8000
PORT=
HOST_PORT=8000

# AI provider. Supported values: deepseek, codex_app_server.
# Default production policy: deepseek is primary; Codex App Server is an optional fallback.
AI_PROVIDER=deepseek

# Optional bot rules overrides.
# AVITO_BOT_RULES_PATH can point to another JSON rules file.
# AVITO_ADMIN_CODE overrides the default admin/debug activation code from bot-rules.json.
AVITO_BOT_RULES_PATH=
AVITO_ADMIN_CODE=

# Runtime storage.
# Leave DATABASE_URL blank for local SQLite. On Bothost, create PostgreSQL and
# paste the connection string here to keep bot state outside the container VM.
DATABASE_URL=
SHARED_DIR=

# Optional explicit SQLite/backup paths. If SHARED_DIR is available and these
# are blank, the app uses $SHARED_DIR/avito-bot/avito-bot.sqlite3 and
# $SHARED_DIR/avito-bot/backups. Otherwise it falls back to .codex-runtime/.
AVITO_DATABASE_PATH=
AVITO_BACKUP_DIR=
AVITO_BACKUP_INTERVAL_SECONDS=21600
AVITO_BACKUP_RETENTION_COUNT=14

# DeepSeek AI assistant credentials.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional Codex App Server fallback settings.
# CODEX_APP_SERVER_BASE_URL should point to an OpenAI-compatible API base,
# for example http://127.0.0.1:9876/v1 when the server exposes /chat/completions.
CODEX_APP_SERVER_BASE_URL=
CODEX_APP_SERVER_API_KEY=
CODEX_APP_SERVER_MODEL=codex

# Optional manager handoff notifications through Telegram.
TELEGRAM_BOT_TOKEN=
MANAGER_TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_TIMEOUT_SECONDS=5

# Runtime diagnostics through the external ai_logger package.
# /api/admin/logs is always kept in memory; these options forward the same
# sanitized records to ai_logger plugins/server when configured.
AI_LOGGER_LEVEL=INFO
AI_LOGGER_PROJECT=avito-bot
AI_LOGGER_SERVICE=api
AI_LOGGER_ENVIRONMENT=local
AI_LOGGER_JSONL_PATH=
AI_LOGGER_SERVER_URL=
AI_LOGGER_SERVER_TOKEN=
AI_LOGGER_FALLBACK_JSONL_PATH=.codex-runtime/logs/ai_logger_fallback.jsonl
